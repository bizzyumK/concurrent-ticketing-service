// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id        String   @id @default(uuid())
  title     String
  seats     Seat[]
  createdAt DateTime @default(now())
}

//One to Many relation betwen Event and Seat
//eg: one event can have multiple seats
//so, attribute 'eventId' in seat is a foreign key of Event table
model Seat {
  id               String            @id @default(uuid())
  seatNumber       String
  eventId          String
  price            Int
  section          String
  event            Event             @relation(fields: [eventId], references: [id])
  createdAt        DateTime          @default(now())
  reservationSeats ReservationSeat[]

  //it means for a particular event, seat number should be unique 
  //eg: for event A: a1 cannot be repeated like [a1, a1, a2, a3]
  // but for event B: a1 can exist because it is different event
  @@unique([eventId, seatNumber])
}

//it mean only fixed predefined strings are allowed for applied field
enum ReservationStatus {
  HELD
  CONFIRMED
  EXPIRED
  CANCELLED
}

//a single reservation can contain multiple seats at once
//so relation between reservation and reservation seat (1 to many)
model Reservation {
  id        String            @id @default(uuid())
  status    ReservationStatus
  expiresAt DateTime?
  seats     ReservationSeat[]
  createdAt DateTime          @default(now())
}

// NOTE: auta seat multiple reservation ma huna sakxa 
// eg: suppose reservation expired then same seat now can be reserved by other user
model ReservationSeat {
  reservationId String
  seatId        String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  seat          Seat        @relation(fields: [seatId], references: [id])

  //this is a composite primary key which is combination of reservationId and seatId
  @@id([reservationId, seatId])
}
